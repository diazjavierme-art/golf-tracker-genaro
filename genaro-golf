  var pesoObj=parseFloat(ls('peso_obj')||ALUMNO.pesoObjetivo);
  var total=ALUMNO.pesoInicial-pesoObj;
  var bajado=ALUMNO.pesoInicial-pesoActual;
  var pct=Math.max(0,Math.min(100,Math.round((bajado/total)*100)));
  var hoy=new Date().toISOString().slice(0,10);
  c.innerHTML=
    '<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:12px">'+
      '<div style="padding:16px 18px">'+
        '<div style="display:flex;justify-content:space-between;align-items:flex-start">'+
          '<div><div style="font-size:11px;color:var(--muted);text-transform:uppercase;font-weight:700;letter-spacing:.8px">Peso actual</div>'+
            '<div style="font-family:\'DM Serif Display\',serif;font-size:72px;line-height:.9;color:var(--text);margin-top:4px">'+pesoActual+'</div>'+
            '<div style="font-size:13px;color:var(--muted)">kg · en ayunas</div></div>'+
          '<div style="text-align:right"><div style="font-size:11px;color:var(--muted)">OBJETIVO</div>'+
            '<div style="font-family:\'DM Serif Display\',serif;font-size:36px;color:var(--gold)">'+pesoObj+'</div>'+
            '<div style="font-size:11px;color:var(--muted)">kg</div></div></div>'+
        '<div style="margin-top:12px"><div style="display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:6px">'+
          '<span>Inicio: '+ALUMNO.pesoInicial+' kg</span><span>'+pct+'%</span><span>Meta: '+pesoObj+' kg</span></div>'+
          '<div style="height:6px;background:var(--surface2);border-radius:3px;overflow:hidden">'+
            '<div style="height:100%;width:'+pct+'%;background:linear-gradient(90deg,var(--orange),var(--greenl));border-radius:3px"></div></div>'+
          (bajado>0?'<div style="font-size:11px;color:var(--greenl);margin-top:5px">Has bajado '+bajado.toFixed(1)+' kg · Faltan '+(pesoActual-pesoObj).toFixed(1)+' kg</div>':'')+'</div></div></div>'+
    '<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:12px">'+
      '<div style="font-size:13px;font-weight:700;margin-bottom:10px">Registrar peso de hoy</div>'+
      '<div style="display:flex;gap:8px">'+
        '<input type="number" id="peso-input" placeholder="Ej: 90.5" step="0.1" min="40" max="200" class="field-input" style="margin-top:0">'+
        '<button onclick="guardarPeso()" style="padding:12px 16px;background:var(--green);border:none;border-radius:8px;color:#fff;font-family:\'DM Sans\',sans-serif;font-size:13px;font-weight:600;cursor:pointer;flex-shrink:0">Guardar</button></div></div>'+
    '<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden">'+
      '<div style="padding:12px 16px;border-bottom:1px solid var(--border);font-size:13px;font-weight:700">Historial ('+hist.length+')</div>'+
      (hist.length===0?'<div style="padding:20px;text-align:center;color:var(--muted);font-size:13px">Sin registros aún</div>':
        hist.slice().reverse().slice(0,15).map(function(r,i,arr){
          var prev=i<arr.length-1?arr[i+1].kg:null;
          var delta=prev!==null?(r.kg-prev).toFixed(1):null;
          var deltaCol=delta!==null?(parseFloat(delta)<0?'var(--greenl)':parseFloat(delta)>0?'var(--orange)':'var(--muted)'):'var(--muted)';
          return '<div style="padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px">'+
            '<div style="font-size:11px;color:var(--muted);min-width:70px">'+r.fecha+'</div>'+
            '<div style="font-size:15px;font-weight:700;flex:1">'+r.kg+' kg</div>'+
            (delta?'<div style="font-size:12px;font-weight:600;color:'+deltaCol+'">'+(parseFloat(delta)>0?'+':'')+delta+' kg</div>':'')+
          '</div>';
        }).join('')
      )+'</div>';
}

function guardarPeso(){
  var val=parseFloat(document.getElementById('peso-input').value);
  if(isNaN(val)||val<40||val>200){showToast('⚠️ Peso no válido');return;}
  var hist=getPesoHist();
  var hoy=new Date();var fecha=hoy.toLocaleDateString('es-ES',{day:'2-digit',month:'2-digit',year:'2-digit'});
  hist.push({id:Date.now().toString(),kg:val,fecha:fecha,ts:hoy.toISOString()});
  savePesoHist(hist);document.getElementById('peso-input').value='';
  renderPeso();showToast('⚖️ '+val+' kg guardado');
}

