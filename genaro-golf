function renderTrain(){
  var d=DAYS[currentDay];var col=d.color;
  document.getElementById('golf-container').innerHTML=d.blocks.map(function(block){
    var total=block.exercises.length;
    var done=block.exercises.filter(function(e){return(currentSession[e.id]||{}).done>0;}).length;
