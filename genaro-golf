function renderApJugadoresList(){
  var el=document.getElementById('ap-jugadores-list');if(!el)return;
  if(!apuestaJugadores.length){el.innerHTML='<div style="font-size:12px;color:var(--muted);text-align:center;padding:8px">Añade jugadores arriba</div>';return;}
  el.innerHTML=apuestaJugadores.map(function(j,i){
    return '<div style="display:flex;align-items:center;gap:8px;background:var(--surface2);border-radius:10px;padding:10px 12px">'+
      '<div style="flex:1;font-size:14px;font-weight:600">'+j.nombre+'</div>'+
      '<div style="display:flex;align-items:center;gap:6px">'+
        '<span style="font-size:12px;color:var(--muted)">€</span>'+
