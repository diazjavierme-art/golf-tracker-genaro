function setTipoRonda(n){
  currentHoyos=n;
  var btn18=document.getElementById('btn-18h');var btn9=document.getElementById('btn-9h');
  if(!btn18||!btn9)return;
  if(n===18){btn18.style.border='2px solid var(--green)';btn18.style.background='rgba(224,120,48,.15)';btn18.style.color='var(--greenl)';btn9.style.border='1px solid var(--border)';btn9.style.background='var(--surface2)';btn9.style.color='var(--muted)';}
  else{btn9.style.border='2px solid var(--green)';btn9.style.background='rgba(224,120,48,.15)';btn9.style.color='var(--greenl)';btn18.style.border='1px solid var(--border)';btn18.style.background='var(--surface2)';btn18.style.color='var(--muted)';}
