  if(tab==='entreno'){
    entrenoSub.style.display='block';rondasSub.style.display='none';
    saveBtn.style.display='block';badge.style.display='none';renderTrain();
  }else if(tab==='rondas'){
    entrenoSub.style.display='none';rondasSub.style.display='block';
    saveBtn.style.display='none';badge.style.display='inline-block';
    document.querySelectorAll('#golf-rondas-sub .tab').forEach(function(t,i){t.classList.toggle('active',i===0);});
    renderRondas('registro');
  }else{
    entrenoSub.style.display='none';rondasSub.style.display='none';
    saveBtn.style.display='none';badge.style.display='none';renderApuestas();
  }
}

