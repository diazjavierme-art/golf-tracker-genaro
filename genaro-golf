function renderHCPCard(){
  var hcp=getHCP(),obj=getObj(),hist=getHist();
  var el=document.getElementById('hcp-current');if(!el)return;
  el.textContent=hcp.toFixed(1);
  document.getElementById('hcp-obj-display').textContent=obj.toFixed(1);
  document.getElementById('home-badge').textContent='HCP '+hcp.toFixed(1);
  var start=ALUMNO.hcpInicial;
  var pct=start-obj>0?Math.max(0,Math.min(100,Math.round(((start-hcp)/(start-obj))*100))):0;
  document.getElementById('hcp-progress-fill').style.width=pct+'%';
  document.getElementById('hcp-progress-label').textContent=pct+'% · '+(hcp-obj>0?'Faltan '+(hcp-obj).toFixed(1):'¡Objetivo!');
  var trendEl=document.getElementById('hcp-trend');
  if(hist.length<2){trendEl.textContent='Sin cambios aún';trendEl.className='hcp-trend';}
  else{
    var diff=hcp-hist[0].hcp;
    if(diff<0){trendEl.textContent='⬇ '+Math.abs(diff).toFixed(1)+' pts mejorado';trendEl.className='hcp-trend good';}
    else if(diff>0){trendEl.textContent='⬆ '+diff.toFixed(1)+' pts subido';trendEl.className='hcp-trend bad';}
    else{trendEl.textContent='→ Sin cambios';trendEl.className='hcp-trend';}
  }
  var dateEl=document.getElementById('hcp-last-updated');
  if(hist.length>0){var d=new Date(hist[hist.length-1].date).toLocaleDateString('es-ES',{day:'2-digit',month:'short',year:'2-digit'});dateEl.textContent='Actualizado '+d;}
  var wrap=document.getElementById('hcp-mini-wrap'),bars=document.getElementById('hcp-mini-bars');
  if(hist.length>=2){
    wrap.style.display='block';
    var vals=hist.slice(-10).map(function(h){return h.hcp;});
    var minV=Math.min.apply(null,vals),maxV=Math.max.apply(null,vals),range=maxV-minV||1;
    bars.innerHTML=hist.slice(-10).map(function(h,i,arr){
      var norm=1-((h.hcp-minV)/range);var ht=Math.max(5,Math.round(norm*22)+5);var isLast=i===arr.length-1;
      var col=isLast?'var(--greenl)':(h.hcp<=arr[0].hcp?'var(--success)':'var(--orange)');
      return '<div class="hcp-mini-bar" style="background:'+col+';height:'+ht+'px;opacity:'+(isLast?1:.7)+'" title="'+h.hcp.toFixed(1)+'"></div>';
    }).join('');
  }else{wrap.style.display='none';}
}

function calcStreak(){
  if(!sessions.length)return 0;
  var dates=[...new Set(sessions.map(function(s){return s.date;}))].sort().reverse();
  var streak=0,d=new Date();d.setHours(0,0,0,0);
  for(var i=0;i<dates.length;i++){
    var sd=new Date(dates[i]);sd.setHours(0,0,0,0);
    var diff=Math.round((d-sd)/86400000);
    if(diff===0||diff===1){streak++;d=sd;}else break;
  }
  return streak;
}

function renderWeekGrid(){
  var grid=document.getElementById('week-grid');
  var today=new Date();today.setHours(0,0,0,0);
  var dow=(today.getDay()+6)%7;
  var days=['L','M','X','J','V','S','D'];
  var datesSet=new Set(sessions.map(function(s){return s.date;}));
  grid.innerHTML=Array.from({length:7}).map(function(_,i){
    var d=new Date(today);d.setDate(d.getDate()-dow+i);
    var ds=d.toISOString().slice(0,10);
    var isToday=i===dow,done=datesSet.has(ds);
    return '<div class="week-day '+(done?'done':'')+(isToday?' today':'')+'">'+
      (done?'✓':days[i])+'<div class="week-day-label">'+d.getDate()+'</div></div>';
  }).join('');
}

