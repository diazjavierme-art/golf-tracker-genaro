        '<div style="padding:10px 16px 6px;background:'+col+'11;border-bottom:1px solid '+col+'33">'+
          '<div class="obj-chip">🎯 '+block.objetivo+'</div></div>'+
        block.exercises.map(function(ex){return renderEx(ex,col);}).join('')+
      '</div></div>';
  }).join('');
}

function renderEx(ex,col){
  var val=(currentSession[ex.id]||{}).done||0;
  var notes=(currentSession[ex.id]||{}).notes||'';
  var pct=Math.min(100,Math.round((val/ex.target)*100));
  var fillCol=pct>=80?'var(--greenl)':pct>=50?'var(--gold)':'var(--orange)';
  return '<div class="exercise">'+
    '<div class="ex-name">'+ex.name+'</div><div class="ex-desc">'+ex.desc+'</div>'+
    '<div class="ex-meta">Meta: '+ex.meta+'</div>'+
    '<div class="counter-row">'+
      '<div class="counter">'+
        '<button class="cnt-btn cnt-minus" onclick="adj(\''+ex.id+'\','+ex.target+',-1)">−</button>'+
        '<div class="cnt-val" id="val-'+ex.id+'">'+val+'</div>'+
        '<button class="cnt-btn cnt-plus" onclick="adj(\''+ex.id+'\','+ex.target+',1)">+</button>'+
      '</div>'+
      '<div style="text-align:right;font-size:12px;color:'+col+';font-weight:700">'+val+'/'+ex.target+'</div>'+
    '</div>'+
    '<div class="kpi-bar"><div class="kpi-fill" id="fill-'+ex.id+'" style="width:'+pct+'%;background:'+fillCol+'"></div></div>'+
    '<div class="kpi-label"><span>'+val+' de '+ex.target+'</span><span>'+pct+'%</span></div>'+
    '<textarea class="notes-area" placeholder="Notas..." rows="2" onchange="saveNote(\''+ex.id+'\',this.value)">'+notes+'</textarea>'+
  '</div>';
}

function toggleBlock(id){var el=document.getElementById('ex-'+id);el.style.display=el.style.display==='none'?'block':'none';}

function adj(exId,target,delta){
  if(!currentSession[exId])currentSession[exId]={done:0,notes:''};
  var v=Math.max(0,(currentSession[exId].done||0)+delta);
  currentSession[exId].done=v;
  localStorage.setItem(PFX+'draft_d'+currentDay,JSON.stringify(currentSession));
  var valEl=document.getElementById('val-'+exId);var fillEl=document.getElementById('fill-'+exId);
  if(!valEl)return;
  valEl.textContent=v;
  var pct=Math.min(100,Math.round((v/target)*100));
  var col=pct>=80?'var(--greenl)':pct>=50?'var(--gold)':'var(--orange)';
  fillEl.style.width=pct+'%';fillEl.style.background=col;
  var kpi=fillEl.closest('.exercise').querySelector('.kpi-label');
  if(kpi){kpi.children[0].textContent=v+' de '+target;kpi.children[1].textContent=pct+'%';}
  if(navigator.vibrate)navigator.vibrate(10);
  var block=null;
  Object.values(DAYS[currentDay].blocks).forEach(function(b){if(b.exercises.some(function(e){return e.id===exId;}))block=b;});
  if(block){
    var done=block.exercises.filter(function(e){return(currentSession[e.id]||{}).done>0;}).length;
    var badge=document.querySelector('#block-'+block.id+' .card-badge');
    if(badge){badge.textContent=done+'/'+block.exercises.length;badge.className='card-badge'+(done===block.exercises.length?' done':'');}
  }
}

function saveNote(exId,val){
  if(!currentSession[exId])currentSession[exId]={done:0,notes:''};
  currentSession[exId].notes=val;
  localStorage.setItem(PFX+'draft_d'+currentDay,JSON.stringify(currentSession));
}

function saveSession(){
  var d=DAYS[currentDay];
  var total=d.blocks.reduce(function(s,b){return s+b.exercises.reduce(function(s2,e){return s2+e.target;},0);},0);
  var done=d.blocks.reduce(function(s,b){return s+b.exercises.reduce(function(s2,e){return s2+(currentSession[e.id]||{done:0}).done;},0);},0);
  var score=Math.min(100,Math.round((done/total)*100));
  var hoy=new Date().toISOString().slice(0,10);
  document.getElementById('modal-title').textContent='📅 ¿Cuándo hiciste esta sesión?';
  document.getElementById('modal-body').innerHTML='<input id="session-date-input" type="date" value="'+hoy+'" class="field-input" style="margin-top:0">';
  document.getElementById('modal-confirm').textContent='Guardar sesión';
  document.getElementById('modal-confirm').onclick=function(){
    var dateVal=document.getElementById('session-date-input').value||hoy;
    sessions.push({date:dateVal,day:currentDay,data:JSON.parse(JSON.stringify(currentSession)),score:score});
    saveAll();localStorage.removeItem(PFX+'draft_d'+currentDay);currentSession={};
    closeModal();renderTrain();
    showToast((score>=85?'🔥':score>=65?'✅':'📈')+' '+score+'% completado');
    renderHome();
  };
  document.getElementById('modal').classList.add('open');
}

