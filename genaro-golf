<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Golf Genaro">
<meta name="theme-color" content="#e07830">
<title>Golf · Genaro</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#f5f2ee;--surface:#ffffff;--surface2:#f0ece6;--border:#e8e0d4;
  --green:#e07830;--greenl:#c85e1a;--gold:#d4920a;--orange:#e0623a;
  --red:#d94040;--text:#1a1208;--muted:#8a7060;--radius:14px;
  --accent:#e07830;--accent2:#f5a054;--success:#2d8a4e;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{background:var(--bg)}
body{font-family:DM Sans,sans-serif;background:var(--bg);color:var(--text);min-height:100dvh;overflow-x:hidden;-webkit-tap-highlight-color:transparent}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
@keyframes pop{0%{transform:scale(1)}30%{transform:scale(1.08)}100%{transform:scale(1)}}
#nav{position:fixed;bottom:0;left:0;right:0;z-index:100;background:var(--surface);border-top:1px solid var(--border);display:flex;padding-bottom:env(safe-area-inset-bottom,0);box-shadow:0 -2px 12px rgba(0,0,0,.06)}
.nav-btn{flex:1;padding:10px 4px 6px;border:none;background:none;color:var(--muted);font-family:DM Sans,sans-serif;font-size:10px;font-weight:500;display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;transition:color .2s;min-width:44px}
.nav-btn svg{width:22px;height:22px}
.nav-btn.active{color:var(--accent)}
.screen{display:none;min-height:calc(100dvh - 58px);padding-bottom:calc(68px + env(safe-area-inset-bottom,0px));background:var(--bg)}
.screen.active{display:block;animation:fadeIn .2s ease}
.header{padding:0;border-bottom:none;position:sticky;top:0;z-index:50}
.header-inner{background:var(--accent);padding:12px 18px 10px;padding-top:calc(12px + env(safe-area-inset-top,0px))}
.header-top{display:flex;justify-content:space-between;align-items:center}
.header h1{font-family:'DM Serif Display',serif;font-size:22px;color:#fff;letter-spacing:-.3px}
.header p{font-size:12px;color:rgba(255,255,255,.75);margin-top:2px}
.badge{background:rgba(255,255,255,.25);color:#fff;font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;border:1px solid rgba(255,255,255,.3)}
.header-tabs{background:var(--surface);border-bottom:1px solid var(--border);display:flex;overflow-x:auto;scrollbar-width:none}
.header-tabs::-webkit-scrollbar{display:none}
.htab{flex:1;min-width:60px;padding:10px 8px;border:none;background:none;color:var(--muted);font-family:DM Sans,sans-serif;font-size:12px;font-weight:600;cursor:pointer;border-bottom:2px solid transparent;transition:all .2s;white-space:nowrap;text-align:center}
.htab.active{color:var(--accent);border-bottom-color:var(--accent)}
.wrap{padding:14px 18px;display:flex;flex-direction:column;gap:12px}
.card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.card-header{padding:14px 16px;display:flex;justify-content:space-between;align-items:center;cursor:pointer}
.card-title{display:flex;align-items:center;gap:10px}
.card-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.card-name{font-size:15px;font-weight:700;color:var(--text)}
.card-sub{font-size:11px;color:var(--muted);margin-top:2px}
.card-badge{font-size:12px;font-weight:700;padding:4px 10px;border-radius:20px;background:var(--surface2);color:var(--muted)}
.card-badge.done{color:var(--success);background:rgba(45,138,78,.1)}
.exercises{border-top:1px solid var(--border)}
.exercise{padding:14px 16px;border-bottom:1px solid var(--border);background:var(--surface)}
.exercise:last-child{border-bottom:none}
.ex-name{font-size:14px;font-weight:600;margin-bottom:4px;color:var(--text)}
.ex-desc{font-size:12px;color:var(--muted);line-height:1.55;margin-bottom:10px}
.ex-meta{font-size:12px;font-weight:600;color:var(--accent);margin-bottom:8px}
.counter-row{display:flex;align-items:center;justify-content:space-between}
.counter{display:flex;align-items:center;gap:0}
.cnt-btn{width:40px;height:40px;border:none;border-radius:8px;font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:transform .1s}
.cnt-btn:active{transform:scale(.88)}
.cnt-minus{background:var(--surface2);color:var(--muted)}
.cnt-plus{background:var(--accent);color:#fff}
.cnt-val{min-width:40px;text-align:center;font-size:18px;font-weight:700;color:var(--text)}
.kpi-bar{height:5px;background:var(--surface2);border-radius:3px;overflow:hidden;margin-top:10px}
.kpi-fill{height:100%;border-radius:3px;transition:width .4s ease}
.kpi-label{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-top:4px}
.kpi-label span:last-child{color:var(--accent);font-weight:600}
.notes-area{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;color:var(--text);font-family:DM Sans,sans-serif;font-size:13px;resize:none;margin-top:10px;min-height:60px;outline:none;transition:border-color .2s}
.notes-area:focus{border-color:var(--accent)}
.hcp-hero{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.hcp-top{padding:16px 18px 4px;display:flex;justify-content:space-between;align-items:center}
.hcp-label{font-size:11px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;color:var(--muted)}
.hcp-sessions{font-size:11px;color:var(--muted);background:var(--surface2);border:1px solid var(--border);padding:4px 10px;border-radius:20px}
.hcp-num-row{padding:2px 18px 10px;display:flex;align-items:flex-end;gap:16px}
.hcp-number{font-family:'DM Serif Display',serif;font-size:96px;line-height:.9;color:var(--accent);transition:color .3s}
.hcp-number.improved{color:var(--success)}
.hcp-number.pop{animation:pop .35s ease}
.hcp-meta{display:flex;flex-direction:column;gap:6px;padding-bottom:8px}
.hcp-trend{font-size:13px;font-weight:600;color:var(--muted)}
.hcp-trend.good{color:var(--success)}
.hcp-trend.bad{color:var(--orange)}
.hcp-date{font-size:10px;color:var(--muted)}
.hcp-obj-bar{padding:0 18px 12px}
.hcp-obj-row{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-bottom:6px}
.hcp-obj-row button{background:none;border:none;cursor:pointer;color:var(--muted);font-size:12px}
.hcp-bar-track{height:6px;background:var(--surface2);border-radius:3px;overflow:hidden}
.hcp-bar-fill{height:100%;background:linear-gradient(90deg,var(--accent2),var(--accent));border-radius:3px;transition:width .5s ease}
.hcp-mini{padding:0 18px 10px}
.hcp-mini-label{font-size:10px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
.hcp-mini-bars{display:flex;gap:4px;align-items:flex-end;height:30px}
.hcp-mini-bar{flex:1;border-radius:3px 3px 0 0;min-height:4px;transition:opacity .2s}
.hcp-actions{border-top:1px solid var(--border);display:flex}
.hcp-act{flex:1;padding:11px 4px;border:none;background:none;color:var(--muted);font-family:DM Sans,sans-serif;font-size:10px;font-weight:600;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:3px;border-right:1px solid var(--border);transition:color .2s}
.hcp-act:last-child{border-right:none}
.hcp-act:active{color:var(--accent)}
.hcp-act svg{width:14px;height:14px}
.streak-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;display:flex;align-items:center;gap:14px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.streak-icon{font-size:34px}
.streak-num{font-family:'DM Serif Display',serif;font-size:32px;color:var(--accent)}
.streak-lbl{font-size:12px;color:var(--muted);margin-top:2px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.stat-card h3{font-size:11px;color:var(--muted);font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-bottom:12px}
.week-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
.week-day{aspect-ratio:1;border-radius:8px;background:var(--surface2);display:flex;align-items:center;justify-content:center;font-size:11px;color:var(--muted);font-weight:600;flex-direction:column;gap:2px}
.week-day.done{background:rgba(224,120,48,.15);color:var(--accent)}
.week-day.today{border:2px solid var(--accent);color:var(--text)}
.week-day-label{font-size:9px;color:var(--muted)}
.plan-week{display:flex;flex-direction:column;gap:8px}
.plan-row-item{background:var(--surface);border:1px solid var(--border);border-radius:10px;overflow:hidden;display:grid;grid-template-columns:72px 1fr;box-shadow:0 1px 4px rgba(0,0,0,.03)}
.plan-day-col{background:var(--surface2);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px 6px;border-right:1px solid var(--border)}
.plan-day-name{font-family:'DM Serif Display',serif;font-size:13px;color:var(--accent)}
.plan-day-info{font-size:9px;color:var(--muted);text-align:center;margin-top:2px;letter-spacing:.3px;text-transform:uppercase}
.plan-acts{padding:10px 12px;display:flex;flex-direction:column;gap:4px}
.plan-act-item{display:flex;align-items:center;gap:7px;font-size:12px}
.plan-act-time{font-size:10px;color:var(--muted);min-width:80px;font-weight:500}
.plan-act-label{color:var(--text)}
.cta-btn{width:100%;padding:15px;border:none;border-radius:var(--radius);font-family:'DM Serif Display',serif;font-size:16px;cursor:pointer;transition:opacity .2s;display:flex;align-items:center;justify-content:center;gap:8px}
.cta-btn:active{opacity:.85}
.d1{background:var(--accent);color:#fff}
.d2{background:var(--surface2);color:var(--text);border:1px solid var(--border)}
.toast{position:fixed;bottom:80px;left:50%;transform:translateX(-50%);background:var(--text);color:#fff;padding:10px 20px;border-radius:30px;font-size:13px;font-weight:500;z-index:300;box-shadow:0 4px 24px rgba(0,0,0,.2);opacity:0;pointer-events:none;transition:opacity .3s;white-space:nowrap}
.toast.show{opacity:1}
.modal-overlay{display:none;position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.5);align-items:flex-end;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--surface);width:100%;max-width:430px;border-radius:20px 20px 0 0;padding:0 18px 40px}
.modal-handle{width:36px;height:4px;background:var(--border);border-radius:2px;margin:12px auto 16px}
.modal h2{font-family:'DM Serif Display',serif;font-size:20px;margin-bottom:4px;color:var(--text)}
.modal p{font-size:13px;color:var(--muted);margin-bottom:20px;line-height:1.6}
.modal-actions{display:flex;gap:10px;margin-top:16px}
.btn-primary{flex:1;padding:14px;border:none;border-radius:10px;background:var(--accent);color:#fff;font-family:DM Sans,sans-serif;font-size:14px;font-weight:600;cursor:pointer}
.btn-secondary{flex:1;padding:14px;border:1px solid var(--border);border-radius:10px;background:var(--surface2);color:var(--muted);font-family:DM Sans,sans-serif;font-size:14px;font-weight:600;cursor:pointer}
.field-input{width:100%;background:var(--surface2);border:1.5px solid var(--border);border-radius:10px;padding:12px 14px;color:var(--text);font-family:DM Sans,sans-serif;font-size:16px;outline:none;transition:border-color .2s;-moz-appearance:textfield;appearance:textfield;margin-top:8px}
.field-input:focus{border-color:var(--accent)}
.meal-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:10px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.meal-header{padding:12px 16px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;border-bottom:1px solid var(--border)}
.meal-day{font-size:14px;font-weight:700;color:var(--text)}
.meal-day-sub{font-size:11px;color:var(--muted);margin-top:2px}
.meal-kcal{font-size:12px;font-weight:700;background:rgba(224,120,48,.1);padding:4px 10px;border-radius:20px;color:var(--accent)}
.meal-item{padding:12px 16px;border-bottom:1px solid var(--border);background:var(--surface)}
.meal-item:last-child{border-bottom:none}
.meal-type{font-size:10px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.meal-name{font-size:13px;font-weight:600;margin-bottom:3px;color:var(--text)}
.meal-desc{font-size:12px;color:var(--muted);line-height:1.5}
.meal-macros{display:flex;gap:6px;margin-top:6px;flex-wrap:wrap}
.macro{font-size:11px;font-weight:600;padding:3px 8px;border-radius:20px;background:var(--surface2);border:1px solid var(--border)}
.macro.p{border-color:rgba(45,138,78,.3);color:var(--success)}
.macro.c{border-color:rgba(212,160,23,.3);color:var(--gold)}
.macro.g{border-color:rgba(74,122,174,.3);color:#4a7aae}
.golf-tip{margin-top:8px;padding:8px 10px;background:rgba(224,120,48,.06);border:1px solid rgba(224,120,48,.2);border-radius:8px;font-size:11px;color:var(--accent);line-height:1.45}
.fit-day{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:10px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.fit-day-header{padding:14px 16px;display:flex;justify-content:space-between;align-items:center;cursor:pointer;border-bottom:1px solid var(--border)}
.fit-day-name{font-size:15px;font-weight:700;color:var(--text)}
.fit-day-sub{font-size:11px;color:var(--muted);margin-top:2px}
.fit-ex{padding:14px 16px;border-bottom:1px solid var(--border);background:var(--surface)}
.fit-ex:last-child{border-bottom:none}
.fit-ex-name{font-size:13px;font-weight:700;margin-bottom:4px;color:var(--text)}
.fit-ex-sets{font-size:12px;color:var(--accent);font-weight:600;margin-bottom:3px}
.fit-ex-desc{font-size:12px;color:var(--muted);line-height:1.5}
.report-section{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px;margin-bottom:12px;box-shadow:0 1px 4px rgba(0,0,0,.04)}
.report-section h3{font-size:12px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
.report-btn{width:100%;padding:15px;border:none;border-radius:var(--radius);background:linear-gradient(135deg,#25D366,#128C7E);color:#fff;font-family:DM Sans,sans-serif;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:10px}
.tabs{display:flex;gap:0;background:var(--surface2);border-radius:30px;padding:3px;margin:12px 18px 0}
.tab{flex:1;padding:9px 12px;border:none;border-radius:26px;background:none;color:var(--muted);font-family:DM Sans,sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;text-align:center}
.tab.active{background:var(--surface);color:var(--accent);box-shadow:0 2px 8px rgba(0,0,0,.08)}
.day-tabs{display:flex;gap:8px;padding:14px 18px 0;overflow-x:auto;scrollbar-width:none;background:var(--surface);border-bottom:1px solid var(--border)}
.day-tabs::-webkit-scrollbar{display:none}
.day-tab{flex-shrink:0;padding:10px 16px;border:1.5px solid var(--border);border-radius:30px;background:none;color:var(--muted);font-family:DM Sans,sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:all .2s;white-space:nowrap}
.day-tab.active{background:var(--accent);border-color:var(--accent);color:#fff}
.obj-chip{display:inline-flex;align-items:center;gap:5px;background:rgba(224,120,48,.08);border:1px solid rgba(224,120,48,.25);color:var(--accent);padding:5px 12px;border-radius:20px;font-size:12px;font-weight:500;margin-top:8px}
::-webkit-scrollbar{width:0}
input[type=number]::-webkit-inner-spin-button{-webkit-appearance:none}
</style>
</head>
<body>

<!-- HOY -->
<div class="screen active" id="screen-home">
  <div class="header">
    <div class="header-inner">
      <div class="header-top">
        <div><h1>⛳ Golf · Genaro</h1><p id="home-date">Cargando...</p></div>
        <div style="display:flex;align-items:center;gap:8px">
          <span class="badge" id="home-badge">HCP 8.1</span>
          <div style="width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,.25);border:1.5px solid rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:700;color:#fff">GG</div>
        </div>
      </div>
    </div>
  </div>
  <div class="wrap">
    <div class="hcp-hero">
      <div class="hcp-top"><div class="hcp-label">Handicap Índice</div><div class="hcp-sessions">Sesiones: <span id="sessions-done">0</span></div></div>
      <div class="hcp-num-row">
        <div class="hcp-number" id="hcp-current">8.1</div>
        <div class="hcp-meta">
          <div class="hcp-trend" id="hcp-trend">Sin cambios aún</div>
          <div class="hcp-date" id="hcp-last-updated"></div>
        </div>
      </div>
      <div class="hcp-obj-bar">
        <div class="hcp-obj-row"><span>Objetivo: <span id="hcp-obj-display">3.0</span> <button onclick="editObjetivo()">✏️</button></span><span id="hcp-progress-label"></span></div>
        <div class="hcp-bar-track"><div class="hcp-bar-fill" id="hcp-progress-fill" style="width:0%"></div></div>
      </div>
      <div class="hcp-mini" id="hcp-mini-wrap" style="display:none"><div class="hcp-mini-label">Evolución</div><div class="hcp-mini-bars" id="hcp-mini-bars"></div></div>
      <div class="hcp-actions">
        <button class="hcp-act" onclick="showHCPHistory()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Historial</button>
        <button class="hcp-act" onclick="updateHCP()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>Actualizar</button>
        <button class="hcp-act" onclick="exportarInforme()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Informe</button>
      </div>
    </div>
    <div class="card" style="padding:14px 16px">
      <div style="font-size:13px;font-weight:700;margin-bottom:10px">📊 Actualizar HCP</div>
      <div style="display:flex;gap:8px;align-items:center">
        <input type="number" id="rfeg-hcp-input" placeholder="Nuevo HCP (ej: 7.8)" step="0.1" min="0" max="54" class="field-input" style="margin-top:0">
        <button onclick="guardarHCPManual()" style="padding:12px 16px;background:var(--green);border:none;border-radius:8px;color:#fff;font-family:DM Sans,sans-serif;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;flex-shrink:0">Guardar</button>
      </div>
    </div>
    <div class="streak-card"><div class="streak-icon">🔥</div><div><div class="streak-num" id="streak-num">0</div><div class="streak-lbl">días seguidos de entrenamiento</div></div></div>
    <div class="stat-card"><h3>Esta semana</h3><div class="week-grid" id="week-grid"></div></div>
    <div class="stat-card"><h3>Planning semanal</h3><div class="plan-week" id="plan-week-grid"></div></div>
    <div style="display:flex;flex-direction:column;gap:8px">
      <p style="font-size:12px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;font-weight:700">Iniciar sesión de golf</p>
      <button class="cta-btn d1" onclick="goTrain(1)">🏹 Sesión 1 · Approach + Precisión</button>
      <button class="cta-btn d2" onclick="goTrain(2)">🧠 Sesión 2 · Mental + Gestión de campo</button>
      <button class="cta-btn" onclick="goTrain(3)" style="background:#e0623a;color:#fff">🏌️ Sesión 3 · Práctica libre + Grip</button>
    </div>
  </div>
</div>

<!-- GOLF -->
<div class="screen" id="screen-golf">
  <div class="header">
    <div class="header-inner">
      <div class="header-top">
