function guardarRonda(){
  var golpes=parseInt(document.getElementById('r-golpes').value);
  var putts=parseInt(document.getElementById('r-putts').value);
  var gir=parseInt(document.getElementById('r-gir').value);
  var fir=parseInt(document.getElementById('r-fir').value);
  var hcp=parseFloat(document.getElementById('r-hcp').value);
  var notas=document.getElementById('r-notas').value.trim();
  var fechaVal=document.getElementById('r-fecha').value;
  if(isNaN(golpes)||golpes<50||golpes>150){showToast('⚠️ Golpes no válido');return;}
  if(isNaN(putts)||putts<18||putts>60){showToast('⚠️ Putts no válido');return;}
  if(isNaN(gir)||gir<0||gir>100){showToast('⚠️ GIR no válido');return;}
  if(isNaN(fir)||fir<0||fir>100){showToast('⚠️ FIR no válido');return;}
  var fechaObj=fechaVal?new Date(fechaVal):new Date();
  var fechaStr=fechaObj.toLocaleDateString('es-ES',{day:'2-digit',month:'2-digit',year:'2-digit'});
  var rondas=getRondas();
  rondas.push({id:Date.now().toString(),fecha:fechaStr,ts:fechaObj.toISOString(),hoyos:currentHoyos,golpes:golpes,putts:putts,gir:gir,fir:fir,hcpJuego:isNaN(hcp)?null:hcp,notas:notas});
  saveRondas(rondas);
  ['r-golpes','r-putts','r-gir','r-fir','r-hcp','r-notas'].forEach(function(id){document.getElementById(id).value='';});
  currentHoyos=18;renderRondas('registro');showToast('⛳ Ronda '+golpes+' guardada');
}

function borrarRonda(id){saveRondas(getRondas().filter(function(r){return r.id!==id;}));renderRondas('registro');}

function renderRondasStats(c,rondas){
