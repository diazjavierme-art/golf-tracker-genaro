function apAñadirJugador(){var input=document.getElementById('ap-nuevo-nombre');var nombre=input.value.trim();if(!nombre){showToast('⚠️ Escribe el nombre');return;}apuestaJugadores.push({nombre:nombre,cantidad:0,pagado:false});input.value='';renderApJugadoresList();}
function apCantidad(i,val){apuestaJugadores[i].cantidad=parseFloat(val)||0;}
function apEliminar(i){apuestaJugadores.splice(i,1);renderApJugadoresList();}

function guardarApuesta(){
  if(!apuestaJugadores.length){showToast('⚠️ Añade al menos un jugador');return;}
  var fecha=document.getElementById('ap-fecha').value;
  var notas=document.getElementById('ap-notas').value.trim();
  var apuestas=getApuestas();
  apuestas.push({id:Date.now().toString(),fecha:fecha,notas:notas,jugadores:JSON.parse(JSON.stringify(apuestaJugadores))});
  saveApuestas(apuestas);apuestaJugadores=[];document.getElementById('ap-notas').value='';
  renderApuestas();var neto=apuestaJugadores.reduce?0:apuestas[apuestas.length-1].jugadores.reduce(function(s,j){return s+j.cantidad;},0);
  showToast('💰 Apuesta guardada');
}

function borrarApuesta(id){saveApuestas(getApuestas().filter(function(a){return a.id!==id;}));renderApuestas();}

