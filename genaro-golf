    document.getElementById('modal-body').textContent='Se restaurarán los datos del '+new Date(data.date).toLocaleDateString('es-ES');
    document.getElementById('modal-confirm').textContent='Restaurar';
    document.getElementById('modal-confirm').onclick=function(){
      if(data.sessions){sessions=data.sessions;saveAll();}
      if(data.hcp)ss('hcp',data.hcp);if(data.obj)ss('obj',data.obj);
      if(data.hist)ss('hcp_hist',data.hist);if(data.peso)ss('peso_hist',data.peso);
      if(data.rondas)ss('rondas',data.rondas);if(data.apuestas)ss('apuestas',data.apuestas);
      if(data.palos)ss('palos_hist',data.palos);
      closeModal();renderHome();showToast('✅ Datos restaurados');
    };
    document.getElementById('modal').classList.add('open');
  }catch(e){showToast('❌ Código inválido');}
}


// ═══════════════════════════════════════════
// COMPRA — checkboxes interactivos
// ═══════════════════════════════════════════
function getCompraState(){try{return JSON.parse(localStorage.getItem(PFX+'compra')||'{}');}catch(e){return{};}}
function saveCompraState(s){localStorage.setItem(PFX+'compra',JSON.stringify(s));}

function renderCompra(c){
  var state=getCompraState();
  var total=0,done=0;
  DIETA.compra.forEach(function(cat){total+=cat.items.length;cat.items.forEach(function(item,ii){var key=cat.categoria+'_'+ii;if(state[key])done++;});});
  var pct=total?Math.round((done/total)*100):0;

  var html=
    // CABECERA + PROGRESO
    '<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;margin-bottom:12px">'+
      '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">'+
        '<div style="font-size:13px;color:var(--muted);line-height:1.6">Lista semanal · Ayuno 16:8 · Bajo en carbos</div>'+
        '<div style="font-size:13px;font-weight:700;color:'+(pct===100?'var(--success)':'var(--accent)')+'">'+done+'/'+total+'</div>'+
      '</div>'+
      '<div style="height:6px;background:var(--surface2);border-radius:3px;overflow:hidden;margin-bottom:12px">'+
        '<div style="height:100%;width:'+pct+'%;background:'+(pct===100?'var(--success)':'var(--accent)')+';border-radius:3px;transition:width .4s ease"></div>'+
      '</div>'+
      // BOTONES
      '<div style="display:flex;gap:8px">'+
        '<button onclick="guardarCompra()" style="flex:1;padding:11px;border:none;border-radius:10px;background:var(--green);color:#fff;font-family:DM Sans,sans-serif;font-size:13px;font-weight:700;cursor:pointer">💾 Guardar lista</button>'+
        '<button onclick="nuevaCompra()" style="flex:1;padding:11px;border:1.5px solid var(--border);border-radius:10px;background:var(--surface2);color:var(--muted);font-family:DM Sans,sans-serif;font-size:13px;font-weight:600;cursor:pointer">🔄 Nueva compra</button>'+
      '</div>'+
    '</div>'+
    // CATEGORÍAS CON CHECKBOXES
    DIETA.compra.map(function(cat){
      var catDone=cat.items.filter(function(item,ii){return state[cat.categoria+'_'+ii];}).length;
      return '<div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:10px">'+
        '<div style="padding:11px 16px;background:var(--surface2);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">'+
          '<div style="font-size:13px;font-weight:700">'+cat.categoria+'</div>'+
          '<div style="font-size:11px;color:'+(catDone===cat.items.length&&cat.items.length>0?'var(--success)':'var(--muted)')+'">'+catDone+'/'+cat.items.length+'</div>'+
        '</div>'+
        cat.items.map(function(item,ii){
          var key=cat.categoria+'_'+ii;
          var ck=!!state[key];
          return '<div onclick="toggleCompraItem(\"'+key+'\")" style="padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:14px;cursor:pointer;transition:opacity .2s;opacity:'+(ck?0.45:1)+';background:'+(ck?'rgba(45,138,78,.04)':'transparent')+'">'+
            '<div style="width:24px;height:24px;border-radius:7px;border:2px solid '+(ck?'var(--success)':'var(--border)')+';background:'+(ck?'var(--success)':'transparent')+';display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s">'+
              (ck?'<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>':'')+
            '</div>'+
            '<div style="flex:1">'+
              '<div style="font-size:13px;font-weight:600;color:var(--text);text-decoration:'+(ck?'line-through':'none')+';color:'+(ck?'var(--muted)':'var(--text)')+'">'+item.nombre+'</div>'+
              (item.nota?'<div style="font-size:11px;color:var(--muted);margin-top:1px">'+item.nota+'</div>':'')+
            '</div>'+
            '<div style="font-size:13px;font-weight:700;color:'+(ck?'var(--success)':'var(--greenl)')+'">'+item.gramos+'</div>'+
          '</div>';
        }).join('')+
      '</div>';
    }).join('');

  c.innerHTML=html;
}

function toggleCompraItem(key){
  var state=getCompraState();
  state[key]=!state[key];
  saveCompraState(state);
  renderCompra(document.getElementById('diet-container'));
  if(navigator.vibrate)navigator.vibrate(10);
}

function guardarCompra(){
  var state=getCompraState();
  var total=0,done=0;
  DIETA.compra.forEach(function(cat){total+=cat.items.length;cat.items.forEach(function(item,ii){if(state[cat.categoria+'_'+ii])done++;});});
  showToast('💾 Lista guardada · '+done+'/'+total+' productos');
}

function nuevaCompra(){
  document.getElementById('modal-title').textContent='🔄 Nueva compra';
  document.getElementById('modal-body').textContent='¿Deseleccionar todos los productos? Útil para empezar la compra de la semana siguiente.';
  document.getElementById('modal-confirm').textContent='Nueva compra';
  document.getElementById('modal-confirm').style.background='var(--accent)';
  document.getElementById('modal-confirm').onclick=function(){
    saveCompraState({});
    closeModal();
    renderCompra(document.getElementById('diet-container'));
    showToast('🛒 Lista limpia — lista para la próxima compra');
  };
  document.getElementById('modal').classList.add('open');
}

// ═══════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════
function togglePanel(header){var panel=header.nextElementSibling;panel.style.display=panel.style.display==='none'?'block':'none';}
function showToast(msg){var t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');setTimeout(function(){t.classList.remove('show');},2800);}
function closeModal(){document.getElementById('modal').classList.remove('open');}
document.getElementById('modal').addEventListener('click',function(e){if(e.target===this)closeModal();});

// ═══════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════
function init(){
  loadAll();
  if(!ls('hcp'))ss('hcp',ALUMNO.hcpInicial);
  if(!ls('obj'))ss('obj',ALUMNO.hcpObjetivo);
  if(!ls('peso_obj'))ss('peso_obj',ALUMNO.pesoObjetivo);
  if(!getPalosHist().length){
    var hoy=new Date();
    savePalosHist([{fecha:hoy.toLocaleDateString('es-ES',{day:'2-digit',month:'2-digit',year:'2-digit'}),ts:hoy.toISOString(),palos:PALOS_INIT.map(function(p){return{palo:p.palo,metros:p.metros};})}]);
  }
  renderHome();switchDay(1);
}

if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',init);}else{init();}
</script>
</body>
